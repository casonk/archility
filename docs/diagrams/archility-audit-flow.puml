@startuml
title archility audit flow

start
:parse CLI arguments;
:resolve shared toolchain ownership;
:resolve repository paths;
:inspect baseline artifacts;
:detect code-like markers and source roots;
:inventory diagram formats and toolchain hints;
:count workflows, diagram sources, and render artifacts;
:build recommendations;

if (JSON output?) then (yes)
  :emit JSON payload;
else (no)
  :emit text report;
endif

stop
@enduml
