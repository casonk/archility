@startuml classes_archility
set namespaceSeparator none
class "DrawioBounds" as archility.generate.DrawioBounds {
  bottom : int
  height : int
  left : int
  mid_x : int
  mid_y : int
  right : int
  top : int
  width : int
  x : int
  y : int
}
class "DrawioCellBounds" as archility.render.DrawioCellBounds {
  bottom : float
  height : float
  left : float
  mid_x : float
  mid_y : float
  right : float
  top : float
  width : float
  x : float
  y : float
}
class "GenerateResult" as archility.generate.GenerateResult {
  created : list[str]
  path : str
  rendered : list[str]
  skipped : list[str]
  to_dict() -> dict[str, object]
}
class "PythonDiagramPlan" as archility.render.PythonDiagramPlan {
  project_name : str
  pydeps_outputs : tuple[Path, ...]
  pyreverse_produced_stems : tuple[str, ...]
  pyreverse_render_outputs : tuple[Path, ...]
  pyreverse_sources : tuple[Path, ...]
  repo_root : Path
  targets : tuple[Path, ...]
}
class "PythonModuleInfo" as archility.render.PythonModuleInfo {
  class_count : int
  function_count : int
  is_package : bool
  name : str
  path : Path
}
class "RenderStep" as archility.render.RenderStep {
  command : list[str]
  cwd : str | None
  output : str
  outputs : tuple[str, ...]
  produced_output : str
  produced_outputs : tuple[str, ...]
  source : str
  tool : str
}
class "RepoAudit" as archility.audit.RepoAudit {
  code_like : bool
  diagram_count : int
  diagram_formats : list[str]
  diagram_source_count : int
  has_agents : bool
  has_blueprint : bool
  has_lessons : bool
  path : str
  recommendations : list[str]
  render_artifact_count : int
  source_roots : list[str]
  toolchains : list[str]
  workflow_count : int
  to_dict() -> dict[str, object]
}
@enduml
